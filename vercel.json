{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "</.well-known/agent-skills/index.json>; rel=\"describedby\"; type=\"application/json\""
        },
        {
          "key": "Link",
          "value": "</for-agents.md>; rel=\"alternate\"; type=\"text/markdown\""
        }
      ]
    },
    {
      "source": "/for-agents.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    },
    {
      "source": "/agent-services.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    },
    {
      "source": "/.well-known/agent-skills/(.*)/SKILL.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown; charset=utf-8"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/about",    "destination": "/o-nas",   "permanent": true },
    { "source": "/services", "destination": "/sluzby",  "permanent": true },
    { "source": "/contakt",  "destination": "/kontakt", "permanent": true },
    { "source": "/contact",  "destination": "/kontakt", "permanent": true }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
